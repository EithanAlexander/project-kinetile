# Copy to ".env" in this folder (Docker Compose loads it automatically).
# Spring Boot uses defaults from physics-engine/src/main/resources/application.yml;
# set POSTGRES_* here only to override Docker Compose port/credentials.
#
# If Postgres was first created with different credentials, either match these
# values or remove the volume: docker compose down -v (deletes DB data).
#
# Host port mapped to container 5432. Default 15432 matches physics-engine application.yml.
POSTGRES_HOST_PORT=15432

POSTGRES_DB=projectkinetile
POSTGRES_USER=projectkinetile
POSTGRES_PASSWORD=projectkinetile

# Dashboard nginx published port (full Docker stack).
DASHBOARD_HOST_PORT=8080

# Ingestion firehose wall-clock limit per container (docker-compose ingestion-1 / ingestion-2). Default 1200 = 20 minutes.
INGESTION_MAX_DURATION_SECONDS=1200

# Optional firehose tuning (defaults shown; omit to use defaults).
INGESTION_BATCH_MIN=200
INGESTION_BATCH_MAX=500
INGESTION_BURST_SLEEP_MIN_SECONDS=1.0
INGESTION_BURST_SLEEP_MAX_SECONDS=2.0

# Optional: Python ingestion on the host. Use localhost:9092 when only kafka/postgres run in Docker.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Physics engine (Spring on host). Spring does not load this file; export or use IDE env.
# CORS (comma-separated origins)
# APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# Rate limiting
# APP_RATE_LIMIT_ENABLED=true
# APP_RATE_LIMIT_RPM=60
# REST validation
# APP_API_MAX_QUERY_STRING_LENGTH=128
# APP_API_TIMESERIES_MAX_MONTHS=24
# Kafka (must match ingestion-service topic names and docker-compose topic init)
# APP_KAFKA_RAW_TRAFFIC_TOPIC=raw-traffic-events
# APP_KAFKA_RAW_TRAFFIC_DLQ_TOPIC=raw-traffic-events-dlq
# APP_KAFKA_MAX_PAYLOAD_BYTES=8192
