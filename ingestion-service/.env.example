# Copy to ".env" in this folder (ingestion-service/). Loaded automatically by firehose.py via python-dotenv.
# POSTGRES_* defaults come from repo root ".env" (same credentials as Docker Compose / Spring Boot).
# Values here do not override variables already set in your shell or IDE.
#
# Default Kafka matches repo root docker-compose published port.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Required for tile catalog (must match postgres container / physics-engine datasource).
# POSTGRES_PASSWORD=projectkinetile
# POSTGRES_HOST=localhost
# POSTGRES_HOST_PORT=15432

# Firehose wall-clock limit (default in code is 1200 = 20 minutes if unset everywhere).
INGESTION_MAX_DURATION_SECONDS=1200

# Optional burst tuning (same defaults as firehose.py if omitted).
INGESTION_BATCH_MIN=200
INGESTION_BATCH_MAX=500
INGESTION_BURST_SLEEP_MIN_SECONDS=1.0
INGESTION_BURST_SLEEP_MAX_SECONDS=2.0
